{
  "name": "notlabel-cli",
  "version": "0.2.0",
  "description": "Official CLI for notlabel.org",
  "type": "module",
  "bin": {
    "notlabel": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile notlabel",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
